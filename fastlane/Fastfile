default_platform(:ios)

# ── App Store Connect API key ──────────────────────────────────────────────────
# Set these environment variables before running any lane:
#   FASTLANE_ASC_KEY_ID      — Key ID from App Store Connect (e.g. ABC123DEF4)
#   FASTLANE_ASC_ISSUER_ID   — Issuer ID (UUID) from App Store Connect
#   FASTLANE_ASC_KEY_PATH    — Path to the downloaded .p8 file

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV["FASTLANE_ASC_KEY_ID"],
    issuer_id: ENV["FASTLANE_ASC_ISSUER_ID"],
    key_filepath: ENV["FASTLANE_ASC_KEY_PATH"],
    duration: 1200,
    in_house: false
  )
end

# ── Shared helpers ────────────────────────────────────────────────────────────

def bump_build(api_key)
  increment_build_number(
    xcodeproj: "Pasture.xcodeproj",
    build_number: latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "com.amrith.pasture"
    ) + 1
  )
end

# ── iOS lanes ─────────────────────────────────────────────────────────────────

platform :ios do

  desc "Sync code signing certificates and profiles (App Store)"
  lane :certs do
    match(type: "appstore", readonly: true)
  end

  desc "Build the iOS app (no upload)"
  lane :build_ios do
    match(type: "appstore", readonly: true)
    gym(
      scheme: "Pasture",
      project: "Pasture.xcodeproj",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build/ios",
      output_name: "Pasture.ipa",
      clean: true
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = asc_api_key
    match(type: "appstore", readonly: true)
    bump_build(api_key)
    gym(
      scheme: "Pasture",
      project: "Pasture.xcodeproj",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build/ios",
      output_name: "Pasture.ipa",
      clean: true
    )
    pilot(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false,
      changelog: "Latest build — see release notes."
    )
  end

  desc "Submit the already-uploaded build for App Store review (metadata managed in ASC)"
  lane :release do
    deliver(
      api_key: asc_api_key,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      skip_metadata: true,
      skip_screenshots: true,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  desc "Run unit tests on simulator"
  lane :test do
    run_tests(
      scheme: "PastureTests",
      device: "iPhone 16",
      clean: true
    )
  end

end

# ── macOS lanes ───────────────────────────────────────────────────────────────

platform :mac do

  desc "Sync macOS certificates and profiles"
  lane :certs do
    match(
      type: "appstore",
      platform: "macos",
      readonly: true,
      app_identifier: "com.amrith.pasture.helper"
    )
  end

  desc "Build the macOS Helper app (no upload)"
  lane :build_mac do
    match(
      type: "appstore",
      platform: "macos",
      readonly: true,
      app_identifier: "com.amrith.pasture.helper"
    )
    gym(
      scheme: "PastureHelper",
      project: "Pasture.xcodeproj",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build/macos",
      output_name: "PastureHelper.pkg",
      clean: true
    )
  end

  desc "Build, notarize, and package PastureHelper as a DMG for direct distribution (pasture.sh)"
  lane :mac_dmg do
    api_key = asc_api_key
    root = File.expand_path("..", __dir__)

    match(
      type: "developer_id",
      platform: "macos",
      app_identifier: "com.amrith.pasture.helper",
      readonly: true,
      api_key: api_key
    )

    build_app(
      scheme: "PastureHelper",
      project: "Pasture.xcodeproj",
      configuration: "Release",
      export_method: "developer-id",
      output_directory: "#{root}/build/macos",
      output_name: "PastureHelper",
      clean: true
    )

    notarize(
      package: "#{root}/build/macos/PastureHelper.app",
      bundle_id: "com.amrith.pasture.helper",
      api_key: api_key
    )

    FileUtils.rm_f("#{root}/build/macos/PastureHelper.dmg")

    sh(
      "create-dmg",
      "--volname",        "Pasture for Mac",
      "--volicon",        "#{root}/Assets/app-icon.icns",
      "--background",     "#{root}/Assets/dmg-background-dmg.png",
      "--window-size",    "660", "400",
      "--icon-size",      "100",
      "--icon",           "PastureHelper.app", "170", "200",
      "--app-drop-link",  "490", "200",
      "--hide-extension", "PastureHelper.app",
      "#{root}/build/macos/PastureHelper.dmg",
      "#{root}/build/macos/PastureHelper.app"
    )

    # Set the custom Pasture icon on the DMG file itself
    sh(
      "osascript", "-e",
      "use framework \"AppKit\"\n" \
      "set img to current application's NSImage's alloc()'s initWithContentsOfFile:\"#{root}/Assets/app-icon.icns\"\n" \
      "current application's NSWorkspace's sharedWorkspace()'s setIcon:img forFile:\"#{root}/build/macos/PastureHelper.dmg\" options:0"
    )

    UI.success("DMG ready at #{root}/build/macos/PastureHelper.dmg")
  end

end
